@{
    Layout = null;

    // Return URL used for navigating back to the public homepage
    var returnUrl = Url.Action("Index", "Home");
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <!-- Character encoding and responsive layout settings -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Static page title for admin login -->
    <title>Admin Giriş</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        /* Full-page centered background layout */
        body {
            min-height: 100vh;
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.18), transparent 28%), radial-gradient(circle at bottom right, rgba(37, 99, 235, 0.18), transparent 30%), linear-gradient(135deg, #0f172a 0%, #111827 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            overflow: auto;
        }

        /* Decorative blurred background orb */
        .bg-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.25;
            z-index: 0;
            pointer-events: none;
        }

        /* Top-left decorative orb */
        .bg-orb-1 {
            width: 220px;
            height: 220px;
            top: 60px;
            left: 60px;
            background: #4f46e5;
        }

        /* Bottom-right decorative orb */
        .bg-orb-2 {
            width: 260px;
            height: 260px;
            bottom: 40px;
            right: 40px;
            background: #2563eb;
        }

        /* Main login layout wrapper */
        .login-shell {
            width: 100%;
            max-width: 980px;
            position: relative;
            z-index: 2;
        }

        /* Link back to homepage */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.86);
            text-decoration: none;
            margin-bottom: 16px;
            font-weight: 500;
            transition: 0.2s ease;
        }

            .back-link:hover {
                color: #fff;
                transform: translateX(-2px);
            }

        /* Main glassmorphism login card */
        .login-card {
            border: 0;
            border-radius: 30px;
            overflow: hidden;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(18px);
            box-shadow: 0 25px 60px rgba(0,0,0,0.22);
        }

        /* Left informational panel */
        .login-left {
            background: linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.04));
            color: #fff;
            padding: 42px;
            height: 100%;
            position: relative;
        }

            /* Decorative circle in left panel */
            .login-left::before {
                content: "";
                position: absolute;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
                top: -60px;
                right: -60px;
            }

            /* Decorative circle in left panel */
            .login-left::after {
                content: "";
                position: absolute;
                width: 140px;
                height: 140px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                bottom: -40px;
                left: -40px;
            }

        /* Ensures visible content stays above pseudo elements */
        .login-left-inner {
            position: relative;
            z-index: 2;
        }

        /* Small badge at the top of the left panel */
        .login-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,0.12);
            font-size: 0.85rem;
            margin-bottom: 18px;
        }

        /* Main heading in the left panel */
        .login-title {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 12px;
        }

        /* Descriptive text in the left panel */
        .login-subtitle {
            color: rgba(255,255,255,0.82);
            line-height: 1.8;
            margin-bottom: 28px;
        }

        /* Feature list wrapper */
        .login-feature-list {
            display: grid;
            gap: 12px;
        }

        /* Single feature row */
        .login-feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255,255,255,0.9);
        }

            .login-feature-item i {
                color: #93c5fd;
            }

        /* Right form panel */
        .login-right {
            background: #fff;
            padding: 42px;
        }

        /* Main wrapper spacing */
        .login-shell {
            width: 100%;
            max-width: 980px;
            position: relative;
            z-index: 2;
            margin: auto;
            padding: 20px 0;
        }

        /* Form title */
        .form-title {
            font-size: 1.65rem;
            font-weight: 800;
            color: #111827;
            margin-bottom: 8px;
        }

        /* Form subtitle */
        .form-subtitle {
            color: #6b7280;
            margin-bottom: 24px;
        }

        /* Form label style */
        .form-label {
            font-weight: 600;
            color: #374151;
        }

        /* Wrapper for modern input controls */
        .input-group-modern {
            position: relative;
        }

        /* Left-side icon inside input */
        .input-icon {
            position: absolute;
            top: 50%;
            left: 16px;
            transform: translateY(-50%);
            color: #6b7280;
            z-index: 2;
            pointer-events: none;
        }

        /* Styled input control */
        .form-control-modern {
            border-radius: 16px;
            border: 1px solid #e5e7eb;
            padding: 13px 44px 13px 44px;
            box-shadow: none;
            transition: all 0.2s ease;
        }

            .form-control-modern:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.10);
            }

        /* Password visibility toggle button */
        .password-toggle {
            position: absolute;
            top: 50%;
            right: 14px;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: #6b7280;
            z-index: 2;
        }

            .password-toggle:hover {
                color: #111827;
            }

        /* Main submit button */
        .login-btn {
            border-radius: 16px;
            padding: 13px 18px;
            font-weight: 700;
            box-shadow: 0 14px 26px rgba(37, 99, 235, 0.16);
        }

        /* Development/demo information box */
        .demo-box {
            margin-top: 18px;
            padding: 14px 16px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
        }

        /* Demo box title */
        .demo-box-title {
            font-weight: 700;
            color: #111827;
            margin-bottom: 6px;
        }

        .demo-box small {
            color: #6b7280;
            display: block;
        }

        /* Demo credentials styling */
        .demo-creds {
            margin-top: 8px;
            font-size: 0.92rem;
            color: #374151;
        }

        /* Shared alert styling */
        .alert {
            border-radius: 16px;
        }

        /* Tablet/mobile adjustments */
        @@media (max-width: 991.98px) {
            .login-left,
            .login-right {
                padding: 28px;
            }

            .login-title {
                font-size: 1.6rem;
            }
        }

        /* Short-screen adjustments */
        @@media (max-height: 700px) {
            body {
                align-items: flex-start;
            }

            .login-shell {
                margin-top: 20px;
                margin-bottom: 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Decorative background elements -->
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>

    <div class="login-shell">
        <!-- Return to homepage link -->
        <a href="@returnUrl" class="back-link">
            <i class="bi bi-arrow-left"></i>
            <span>Ana sayfaya dön</span>
        </a>

        <div class="card login-card">
            <div class="row g-0">
                <!-- Left informational side -->
                <div class="col-lg-5">
                    <div class="login-left">
                        <div class="login-left-inner">
                            <div class="login-badge">
                                <i class="bi bi-shield-lock"></i>
                                <span>Yönetim Paneli</span>
                            </div>

                            <div class="login-title">Güvenli Admin Girişi</div>

                            <p class="login-subtitle">
                                Panel erişimi yalnızca yetkili kullanıcılar içindir. Devam etmek için kullanıcı adı ve şifreni gir.
                            </p>

                            <!-- Security-related feature list -->
                            <div class="login-feature-list">
                                <div class="login-feature-item">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Yetkili kullanıcı kontrolü</span>
                                </div>
                                <div class="login-feature-item">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Yönetim paneli erişimi</span>
                                </div>
                                <div class="login-feature-item">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Oturum tabanlı koruma</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right login form side -->
                <div class="col-lg-7">
                    <div class="login-right">
                        <div class="form-title">Hoş geldin</div>
                        <div class="form-subtitle">Giriş bilgilerini doldurarak devam et.</div>

                        <!-- Error message shown after failed login attempt -->
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger border-0 shadow-sm">
                                <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
                            </div>
                        }

                        <!-- Admin login form -->
                        <form method="post" action="@Url.Action("Login", "Auth")" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label">Kullanıcı Adı</label>
                                <div class="input-group-modern">
                                    <i class="bi bi-person input-icon"></i>
                                    <input type="text"
                                           name="username"
                                           class="form-control form-control-modern"
                                           placeholder="Kullanıcı adı"
                                           autocomplete="username"
                                           required
                                           maxlength="50" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Şifre</label>
                                <div class="input-group-modern">
                                    <i class="bi bi-lock input-icon"></i>
                                    <input type="password"
                                           name="password"
                                           id="passwordInput"
                                           class="form-control form-control-modern"
                                           placeholder="Şifre"
                                           autocomplete="current-password"
                                           required
                                           maxlength="100" />
                                    <button type="button" class="password-toggle" id="togglePassword" aria-label="Şifreyi göster/gizle">
                                        <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Submit button -->
                            <button type="submit" class="btn btn-primary w-100 login-btn">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                            </button>

                            <!-- Development-only demo credentials -->
                            <div class="demo-box">
                                <div class="demo-box-title">Geliştirme Notu</div>
                                <small>Bu bilgiler sadece test amaçlı görünür olmalı. Yayın ortamında kaldır.</small>

                                <div class="demo-creds">
                                    <div><strong>Kullanıcı adı:</strong> admin</div>
                                    <div><strong>Şifre:</strong> 123456</div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Password visibility toggle logic
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("passwordInput");
        const togglePasswordIcon = document.getElementById("togglePasswordIcon");

        if (togglePassword && passwordInput) {
            togglePassword.addEventListener("click", function () {
                const isPassword = passwordInput.type === "password";
                passwordInput.type = isPassword ? "text" : "password";
                togglePasswordIcon.className = isPassword ? "bi bi-eye-slash" : "bi bi-eye";
            });
        }
    </script>
</body>
</html>