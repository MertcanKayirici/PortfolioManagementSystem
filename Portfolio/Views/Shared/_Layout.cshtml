<!DOCTYPE html>
<html lang="tr">
<head>
    <!-- Character encoding and responsive meta settings -->
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Dynamic page title -->
    <title>@ViewBag.Title - Mertcan Kayırıcı</title>

    <!-- Bundled project styles -->
    @Styles.Render("~/Content/css")

    <!-- Modernizr bundle for feature detection -->
    @Scripts.Render("~/bundles/modernizr")

    <style>
        /* Global page styling */
        body {
            background: #f8fafc;
            color: #111827;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }

        /* Main fixed top navigation bar */
        .site-navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
            background: rgba(15, 23, 42, 0.92) !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 25px rgba(15, 23, 42, 0.08);
            padding-top: 0.85rem;
            padding-bottom: 0.85rem;
            transition: transform 0.35s ease, background 0.3s ease, box-shadow 0.3s ease;
        }

            /* Transparent navbar state used near the top/hero area */
            .site-navbar.nav-transparent {
                background: transparent !important;
                backdrop-filter: none;
                box-shadow: none;
            }

            /* Hidden navbar state used when scrolling down */
            .site-navbar.nav-hidden {
                transform: translateY(-100%);
            }

            /* Brand/logo text */
            .site-navbar .navbar-brand {
                font-weight: 700;
                font-size: 1.15rem;
                letter-spacing: 0.02em;
                color: #fff !important;
            }

            /* Navigation link styling */
            .site-navbar .nav-link {
                color: rgba(255,255,255,0.88) !important;
                font-weight: 500;
                margin-left: 8px;
                margin-right: 8px;
                transition: 0.2s ease;
                border-radius: 10px;
                padding: 8px 12px !important;
            }

                /* Navigation link hover effect */
                .site-navbar .nav-link:hover {
                    color: #ffffff !important;
                    background: rgba(255,255,255,0.08);
                }

        /* Wrapper for page body content */
        .body-wrapper {
            min-height: calc(100vh - 180px);
            padding-top: 0;
        }

        /* Footer styling */
        .site-footer {
            background: #0f172a;
            color: #cbd5e1;
            margin-top: 40px;
            padding: 28px 0 32px 0;
        }

            /* Footer paragraph spacing */
            .site-footer p {
                margin-bottom: 6px;
            }

        /* Small hidden admin entry link inside footer */
        .admin-hidden-entry {
            display: inline-block;
            text-decoration: none;
            color: #94a3b8;
            font-size: 10px;
            line-height: 1;
            opacity: 0.2;
            transition: 0.2s ease;
            user-select: none;
        }

            /* Hidden admin entry hover effect */
            .admin-hidden-entry:hover {
                opacity: 0.65;
                color: #e2e8f0;
            }

        /* Remove default outline/border from navbar toggler */
        .navbar-toggler {
            border: 0 !important;
            box-shadow: none !important;
        }

        /* Mobile-specific nav spacing */
        @@media (max-width: 768px) {
            .site-navbar .nav-link {
                margin: 4px 0;
            }
        }
    </style>
</head>
<body>

    <!-- MAIN SITE NAVBAR -->
    <nav id="siteNavbar" class="navbar navbar-expand-lg navbar-dark site-navbar nav-transparent">
        <div class="container">
            <!-- Brand link -->
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">Mertcan Kayırıcı</a>

            <!-- Mobile navbar toggle button -->
            <button type="button"
                    class="navbar-toggler"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    title="Menüyü Aç/Kapat"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Collapsible navigation links -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")" class="nav-link">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")#about" class="nav-link">Hakkımda</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")#skills" class="nav-link">Yetenekler</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")#projects" class="nav-link">Projeler</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")#contact" class="nav-link">İletişim</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <main class="body-wrapper">
        @RenderBody()
    </main>

    <!-- SITE FOOTER -->
    <footer class="site-footer text-center">
        <div class="container">
            <!-- Dynamic copyright year -->
            <p class="fw-semibold mb-1">© @DateTime.Now.Year Mertcan Kayırıcı</p>

            <!-- Short role description -->
            <small class="d-block mb-2">Backend Developer / Full Stack Developer</small>

            <!-- Hidden admin login shortcut -->
            <a href="@Url.Action("Login", "Auth")"
               class="admin-hidden-entry"
               title="Admin Girişi">•</a>
        </div>
    </footer>

    <!-- jQuery bundle -->
    @Scripts.Render("~/bundles/jquery")

    <!-- Bootstrap bundle -->
    @Scripts.Render("~/bundles/bootstrap")

    <!-- Optional page-specific scripts -->
    @RenderSection("scripts", required: false)

    <script>
        // Navbar behavior controller:
        // - stays transparent near the top
        // - becomes solid after passing hero threshold
        // - hides on downward scroll
        (function () {
            const navbar = document.getElementById("siteNavbar");
            let lastScrollTop = 0;
            const heroThreshold = window.innerHeight * 0.7;

            function updateNavbar() {
                const currentScroll = window.pageYOffset || document.documentElement.scrollTop;

                // Keep navbar transparent near the top of the page
                if (currentScroll <= 10) {
                    navbar.classList.add("nav-transparent");
                    navbar.classList.remove("nav-hidden");
                }
                // Keep it transparent while still inside the hero area
                else if (currentScroll < heroThreshold) {
                    navbar.classList.add("nav-transparent");
                }
                // Remove transparency after scrolling past hero threshold
                else {
                    navbar.classList.remove("nav-transparent");
                }

                // Hide navbar when scrolling down after a small offset
                if (currentScroll > lastScrollTop && currentScroll > 120) {
                    navbar.classList.add("nav-hidden");
                } else {
                    navbar.classList.remove("nav-hidden");
                }

                lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
            }

            window.addEventListener("scroll", updateNavbar, { passive: true });
            window.addEventListener("resize", updateNavbar);
            updateNavbar();
        })();
    </script>

    <!-- AOS animation library -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS scroll animations
        AOS.init({
            duration: 900,
            once: true,
            offset: 80
        });
    </script>
</body>
</html>