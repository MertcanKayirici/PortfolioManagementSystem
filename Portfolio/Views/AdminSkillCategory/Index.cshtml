@model List<Portfolio.Models.SkillCategories>

@{
    // Use shared admin layout
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Page title shown in layout/topbar
    ViewBag.Title = "Skill Kategorileri";
}

<style>
    /* Header section for title and add button */
    .category-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    /* Shared card styles used across table, filters and stats */
    .category-table-card,
    .filter-card,
    .mini-stat-card {
        border: 0;
        border-radius: 24px;
        box-shadow: 0 12px 35px rgba(15, 23, 42, 0.06);
    }

    /* Table header styling */
    .category-table thead th {
        font-size: 0.9rem;
        color: #6b7280;
        font-weight: 700;
        border-bottom: 1px solid #eef2f7;
        background: #f8fafc;
        padding-top: 14px;
        padding-bottom: 14px;
    }

    /* Table cell spacing */
    .category-table tbody td {
        vertical-align: middle;
        padding-top: 16px;
        padding-bottom: 16px;
        border-color: #f1f5f9;
    }

    /* Row hover effect */
    .category-table tbody tr {
        transition: all 0.2s ease;
    }

        .category-table tbody tr:hover {
            background: #fafcff;
        }

    /* Badge used for system category name */
    .system-badge {
        padding: 0.5rem 0.8rem;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-block;
    }

    /* Badge used for hex color display */
    .hex-badge {
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        color: #374151;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-block;
    }

    /* Wrapper for color preview circle */
    .color-preview-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Color preview circle */
    .color-preview {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 3px solid #eef2f7;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,0.04);
        flex-shrink: 0;
    }

    /* Action button group */
    .action-buttons {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    /* Status switch and label wrapper */
    .status-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Status label text */
    .status-text {
        font-size: 0.85rem;
        font-weight: 600;
        min-width: 42px;
    }

    /* Active state text color */
    .status-active {
        color: #198754;
    }

    /* Passive state text color */
    .status-passive {
        color: #6c757d;
    }

    /* Shared small action button style */
    .table-action-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

        .table-action-btn i {
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            line-height: 1;
            margin: 0;
        }

    /* Empty state box */
    .empty-box {
        text-align: center;
        padding: 48px 16px;
        color: #6b7280;
    }

    /* Shared form control rounding */
    .live-search-input,
    .form-select {
        border-radius: 12px;
    }

    /* Mini stat card */
    .mini-stat-card {
        padding: 18px;
        background: #fff;
        text-align: center;
    }

    /* Mini stat title */
    .mini-stat-title {
        color: #6b7280;
        font-size: 0.82rem;
        margin-bottom: 6px;
    }

    /* Mini stat value */
    .mini-stat-value {
        font-size: 1.35rem;
        font-weight: 700;
    }

    /* Mobile/tablet alignment improvements */
    @@media (max-width: 576px) {
        .category-table td,
        .category-table th {
            text-align: center;
        }

        .color-preview-wrap {
            justify-content: center;
        }

        .action-buttons,
        .status-wrap {
            justify-content: center;
        }
    }
</style>

<!-- PAGE HEADER -->
<div class="category-page-header">
    <div>
        <h2 class="fw-bold mb-0">🎨 Skill Kategorileri</h2>
        <small class="text-muted">Renk ve başlık ayarlarını yönet</small>
    </div>

    <!-- Create new category button -->
    <a href="@Url.Action("Add", "AdminSkillCategory")" class="btn btn-primary px-3">
        <i class="bi bi-plus-circle me-1"></i> Yeni Kategori
    </a>
</div>

<!-- FILTER CARD -->
<div class="card filter-card mb-4">
    <div class="card-body p-4">
        <!-- Filter form for keyword, status, color and sorting -->
        <form method="get" action="@Url.Action("Index", "AdminSkillCategory")" id="filterForm">
            <div class="row g-3">
                <!-- Live search input -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Anlık Ara</label>
                    <input type="text"
                           id="liveSearch"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control live-search-input"
                           placeholder="Kategori adı veya görünen ad..." />
                </div>

                <!-- Status filter -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Durum</label>
                    <select name="status" class="form-select">
                        <option value="">Tümü</option>
                        <option value="active" @(ViewBag.Status == "active" ? "selected" : "")>Aktif</option>
                        <option value="passive" @(ViewBag.Status == "passive" ? "selected" : "")>Pasif</option>
                    </select>
                </div>

                <!-- Color filter -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Renk</label>
                    <select name="color" class="form-select">
                        <option value="">Tüm Renkler</option>
                        @if (ViewBag.ColorList != null)
                        {
                            foreach (var hex in ViewBag.ColorList)
                            {
                                <option value="@hex" @(ViewBag.Color == hex ? "selected" : "")>@hex</option>
                            }
                        }
                    </select>
                </div>

                <!-- Sorting options -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Sırala</label>
                    <select name="sort" class="form-select">
                        <option value="order_asc" @(ViewBag.Sort == "order_asc" ? "selected" : "")>Sıra Artan</option>
                        <option value="order_desc" @(ViewBag.Sort == "order_desc" ? "selected" : "")>Sıra Azalan</option>
                        <option value="name_asc" @(ViewBag.Sort == "name_asc" ? "selected" : "")>Ad A-Z</option>
                        <option value="name_desc" @(ViewBag.Sort == "name_desc" ? "selected" : "")>Ad Z-A</option>
                    </select>
                </div>

                <!-- Filter action buttons -->
                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">
                        Filtrele
                    </button>
                    <a href="@Url.Action("Index", "AdminSkillCategory")" class="btn btn-outline-secondary">
                        Temizle
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- CATEGORY TABLE CARD -->
<div class="card category-table-card">
    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table category-table align-middle mb-0" id="categoryTable">
                    <thead>
                        <tr>
                            <th>Kategori</th>
                            <th>Görünen Ad</th>
                            <th>Renk</th>
                            <th>Hex</th>
                            <th>Durum</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- Internal/system category name -->
                                <td>
                                    <span class="system-badge">
                                        @item.CategoryName
                                    </span>
                                </td>

                                <!-- Display name shown on the public site -->
                                <td class="fw-semibold">
                                    @item.DisplayName
                                </td>

                                <!-- Color preview -->
                                <td>
                                    <div class="color-preview-wrap">
                                        <div class="color-preview"
                                             style="background:@(string.IsNullOrEmpty(item.HexColor) ? "#0d6efd" : item.HexColor);">
                                        </div>
                                    </div>
                                </td>

                                <!-- Hex color code -->
                                <td>
                                    <span class="hex-badge">
                                        @(string.IsNullOrEmpty(item.HexColor) ? "#0d6efd" : item.HexColor)
                                    </span>
                                </td>

                                <!-- Active/passive status with AJAX toggle -->
                                <td>
                                    <div class="status-wrap">
                                        <div class="form-check form-switch m-0">
                                            <input class="form-check-input toggle-status"
                                                   type="checkbox"
                                                   data-id="@item.SkillCategoryId"
                                                   @(item.IsActive ? "checked" : "")>
                                        </div>

                                        <span class="status-text @(item.IsActive ? "status-active" : "status-passive")">
                                            @(item.IsActive ? "Aktif" : "Pasif")
                                        </span>
                                    </div>
                                </td>

                                <!-- Action buttons -->
                                <td class="text-end">
                                    <div class="action-buttons">
                                        <!-- Edit button -->
                                        <a href="@Url.Action("Edit", "AdminSkillCategory", new { id = item.SkillCategoryId })"
                                           class="btn btn-sm btn-outline-warning table-action-btn"
                                           title="Düzenle">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <!-- Delete form -->
                                        <form method="post"
                                              action="@Url.Action("Delete", "AdminSkillCategory")"
                                              class="delete-form m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.SkillCategoryId" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger table-action-btn"
                                                    title="Sil">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <!-- Empty state shown when no categories exist or filter returns no results -->
            <div class="empty-box">
                <i class="bi bi-palette fs-1 d-block mb-3"></i>
                <div class="fw-semibold mb-1">Henüz kategori bulunmuyor</div>
                <small>Filtre sonucunda kayıt bulunamadı.</small>
            </div>
        }
    </div>
</div>

<script>
    // Delete confirmation with SweetAlert2
    document.querySelectorAll('.delete-form').forEach(form => {
        form.addEventListener('submit', function (e) {
            e.preventDefault();

            Swal.fire({
                title: 'Emin misin?',
                text: 'Bu kategori silinecek!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, sil',
                cancelButtonText: 'Vazgeç',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });

    // AJAX status toggle logic
    document.querySelectorAll(".toggle-status").forEach(el => {
        el.addEventListener("change", function () {
            const checkbox = this;
            const id = checkbox.getAttribute("data-id");
            const statusText = checkbox.closest(".status-wrap").querySelector(".status-text");
            const oldState = !checkbox.checked;

            fetch('@Url.Action("Toggle", "AdminSkillCategory")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'id=' + id
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (data.status) {
                        statusText.textContent = "Aktif";
                        statusText.classList.remove("status-passive");
                        statusText.classList.add("status-active");
                    } else {
                        statusText.textContent = "Pasif";
                        statusText.classList.remove("status-active");
                        statusText.classList.add("status-passive");
                    }
                } else {
                    checkbox.checked = oldState;
                    alert("Hata oluştu");
                }
            })
            .catch(() => {
                checkbox.checked = oldState;
                alert("Bağlantı hatası");
            });
        });
    });

    // Live search: auto-submit the filter form after a short delay
    let searchTimeout;
    const liveSearch = document.getElementById("liveSearch");
    const filterForm = document.getElementById("filterForm");

    if (liveSearch) {
        liveSearch.addEventListener("input", function () {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                filterForm.submit();
            }, 400);
        });
    }
</script>